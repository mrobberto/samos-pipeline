def slit_profile(diff, slitid, sid, min_width=5):
    import numpy as np

    p = np.full(diff.shape[0], np.nan)

    for y in range(diff.shape[0]):
        xs = np.where(slitid[y] == sid)[0]

        # reject tiny islands (like your bad column)
        if xs.size < min_width:
            continue

        vals = diff[y, xs]
        vals = vals[np.isfinite(vals)]
        if vals.size > 0:
            p[y] = np.nanmedian(vals)

    return p



